{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "anki_web",
      "github"
    ],
    "properties": {
      "id": {
        "type": "integer"
      },
      "anki_web": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "addon_page_url",
          "rating",
          "update_date",
          "anki_version",
          "branches",
          "links",
          "likes",
          "dislikes"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "addon_page_url": {
            "type": "string"
          },
          "rating": {
            "type": "integer"
          },
          "update_date": {
            "type": "string"
          },
          "anki_version": {
            "type": "string"
          },
          "branches": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "min_version": {
                  "type": "string"
                },
                "max_version": {
                  "type": [
                    "null",
                    "string"
                  ]
                },
                "updated": {
                  "type": "string"
                }
              },
              "required": [
                "max_version",
                "min_version",
                "updated"
              ]
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "likes": {
            "type": "integer"
          },
          "dislikes": {
            "type": "integer"
          }
        }
      },
      "github": {
        "anyOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "action_count",
              "languages",
              "last_commit",
              "links",
              "repo",
              "stars",
              "tests_count",
              "user"
            ],
            "properties": {
              "user": {
                "type": "string"
              },
              "repo": {
                "type": "string"
              },
              "languages": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "stars": {
                "type": "integer"
              },
              "last_commit": {
                "type": [
                  "null",
                  "string"
                ]
              },
              "links": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string"
                    },
                    "user": {
                      "type": "string"
                    },
                    "repo": {
                      "type": [
                        "null",
                        "string"
                      ]
                    }
                  },
                  "required": [
                    "repo",
                    "url",
                    "user"
                  ]
                }
              },
              "action_count": {
                "type": [
                  "integer",
                  "null"
                ]
              },
              "tests_count": {
                "type": [
                  "integer",
                  "null"
                ]
              }
            }
          }
        ]
      },
      "forum": {
        "type": [
          "object",
          "null"
        ],
        "additionalProperties": false,
        "required": [
          "anki_forum_url"
        ],
        "properties": {
          "anki_forum_url": {
            "type": "string"
          },
          "topic_slug": {
            "type": "string"
          },
          "topic_id": {
            "type": "integer"
          },
          "last_posted_at": {
            "type": "string"
          },
          "posts_count": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      }
    }
  }
}
