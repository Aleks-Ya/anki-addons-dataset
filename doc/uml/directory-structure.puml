@startuml
skinparam linetype ortho
skinparam ArrowColor red

folder ~ {
    folder anki-addons-dataset {
        folder bundle {
        together {
            folder ".cache"
            file README.md
            file "bundle-metadata.json" as metadataJsonHistory
        }
        folder history as datasetHistory {
            file "2025-06-22.zip" as zip
        }
        folder latest
        }
        folder history {
            folder "2025-06-22" as historyDate {
            together {
                folder "1-raw" {
                    file "raw-metadata.json"
                }
                folder "2-stage"
                folder "3-final" as historyFinal
            }
            file "version-metadata.json"  as versionMetadata
            }
        }
    }
}

cloud HuggingFace {
    artifact "Ya-Alex/anki-addons" as dataset <<Dataset>>
}

historyFinal --> latest
historyDate --> zip
bundle --> dataset

@enduml